# Clash Royale API tokens (comma-separated for multiple friends' tokens)
CR_API_TOKENS=your_token_here,friends_token_here

# Leave these as-is for local Docker setup
REDIS_URL=redis://redis:6379
DATABASE_URL=postgresql+asyncpg://cr:cr@postgres:5432/cr_analyzer
CACHE_TTL_SECONDS=600
DEBUG=true
LOG_LEVEL=INFO
